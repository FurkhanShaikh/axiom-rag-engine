# ── Search ────────────────────────────────────────────────────────────────────
# Tavily powers live web retrieval. Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── LLM: Local (Ollama) — free, no API cost ───────────────────────────────────
# Install Ollama: https://ollama.com
# Pull a model:  ollama pull qwen3.5:9b
# Then pass in the request body:
#   "models": { "synthesizer": "ollama/qwen3.5:9b", "verifier": "ollama/qwen3.5:9b" }
OLLAMA_API_BASE=http://localhost:11434

# ── LLM: Cloud (optional, higher quality) ─────────────────────────────────────
# Uncomment if you prefer cloud models over Ollama.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here   # for claude-3-5-sonnet-20241022
# OPENAI_API_KEY=your_openai_api_key_here          # for gpt-4o-mini

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Default: 20 requests per minute per IP. Increase for high-traffic deployments.
# AXIOM_RATE_LIMIT=20/minute

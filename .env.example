# ──────────────────────────────────────────────────────────────────────────────
# Axiom Engine — reference .env template
#
# Copy to `.env` and edit. All AXIOM_* variables are parsed by
# `axiom_rag_engine.config.settings.Settings`. Run `axiom-rag-engine check-config`
# to see the resolved values with their source (env / .env / default).
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
# Environment tier. Non-development values REQUIRE AXIOM_API_KEYS.
# Valid: production (default), development, dev, local, test
# AXIOM_ENV=development

# Set to "false" to disable /docs and /redoc in production.
# AXIOM_DOCS_ENABLED=true

# ── Authentication ───────────────────────────────────────────────────────────
# Comma-separated API keys. Required when AXIOM_ENV is production.
# AXIOM_API_KEYS=key1,key2,key3

# ── Search ───────────────────────────────────────────────────────────────────
# Tavily powers live web retrieval. Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# In non-development environments, live search is required unless you explicitly
# opt into mock retrieval for isolated testing.
# AXIOM_ALLOW_MOCK_SEARCH=false

# ── LLM: Local (Ollama) — free, no API cost ──────────────────────────────────
# Install Ollama: https://ollama.com  then  ollama pull qwen3.5:9b
# Specify per-request:
#   "models": { "synthesizer": "ollama/qwen3.5:9b", "verifier": "ollama/qwen3.5:9b" }
OLLAMA_API_BASE=http://localhost:11434

# ── LLM: Cloud ───────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here   # for claude-sonnet-4-5
# OPENAI_API_KEY=your_openai_api_key_here          # for gpt-4o-mini

# Default model IDs when not specified in the request body.
# AXIOM_DEFAULT_SYNTHESIZER_MODEL=claude-sonnet-4-5
# AXIOM_DEFAULT_VERIFIER_MODEL=gpt-4o-mini

# ── LLM budget & concurrency ─────────────────────────────────────────────────
# Hard caps per request (protect wallet + tail latency).
# AXIOM_MAX_LLM_CALLS_PER_REQUEST=64
# AXIOM_MAX_TOKENS_PER_REQUEST=0               # 0 = unlimited
# AXIOM_MAX_CONCURRENT_LLM=5                   # global semaphore

# Prometheus label allowlist for the `model` dimension (bounds cardinality).
# AXIOM_ALLOWED_METRIC_MODELS=claude-sonnet-4-5,gpt-4o-mini,ollama

# ── Rate limiting & response cache ───────────────────────────────────────────
# Default: 20 requests per minute per API key (or IP for unauthenticated).
# AXIOM_RATE_LIMIT=20/minute
# AXIOM_CACHE_TTL_SECONDS=300
# AXIOM_CACHE_MAX_SIZE=256
# Optional Redis for multi-worker deployments.
# AXIOM_REDIS_URL=redis://localhost:6379/0

# ── Verification policy ──────────────────────────────────────────────────────
# Server-enforced. Callers cannot override these via the request body.
# AXIOM_SEMANTIC_VERIFICATION_ENABLED=true
# AXIOM_MIN_USABLE_RANKING_SCORE=0.15
# AXIOM_AUTHORITATIVE_DOMAINS=internal.example.com
# AXIOM_LOW_QUALITY_DOMAINS=blogs.example.com
# AXIOM_EXCLUDE_DEFAULT_DOMAINS=en.wikipedia.org

# ── Security & limits ────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins. Empty = reject cross-origin requests.
# AXIOM_CORS_ORIGINS=https://your-frontend.example.com

# Only trust X-Forwarded-For when the immediate caller is in this allowlist.
# Use "*" ONLY behind a trusted private ingress.
# AXIOM_TRUSTED_PROXY_IPS=10.0.0.10,10.0.0.11

# Hard cap on request body size in bytes (default 128 KiB).
# AXIOM_MAX_BODY_BYTES=131072

# ── Audit & logging ──────────────────────────────────────────────────────────
# In-memory retention of the last N audit trails, fetched via
# `GET /v1/audits/{request_id}` or `axiom-rag-engine audit <request_id>`.
# 0 disables retention. Enabled by default so the UI's Audit Log page works
# out of the box; lower or zero it in memory-constrained production.
AXIOM_AUDIT_RETENTION=200

# When true, every audit event is also emitted as a structured log line
# (best combined with LOG_FORMAT=json for log-aggregator ingestion).
# AXIOM_LOG_AUDIT_EVENTS=false

# ── Observability ────────────────────────────────────────────────────────────
# Log format: "text" (default, human-readable) or "json" (structured).
# LOG_FORMAT=text

# OpenTelemetry: set OTLP endpoint to enable distributed tracing.
# When unset, tracing is disabled (zero overhead).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=axiom-rag-engine
